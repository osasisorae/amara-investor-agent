# ============================================
# Amara Investor Agent - Environment Variables
# Qwen Cloud Hackathon - Track 4: Autopilot Agent
# ============================================

# --- Qwen Cloud API (Agent Reasoning) ---
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE_URL=https://your-workspace.maas.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Database (Turso - Persistent Memory & Audit Trail) ---
DATABASE_URL=libsql://your-database.turso.io
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# --- Email (Resend - Outreach & Agreement Delivery) ---
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=her@investfuturex.com

# --- File Storage (KYC Documents) ---
FILE_STORAGE_PROVIDER=vercel-blob
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# --- Authentication & Security ---
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password_here

# --- OTP Service (for Agreement Signing) ---
OTP_PROVIDER=resend
OTP_EXPIRES_IN_MINUTES=15

# --- App Configuration ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Feature Flags ---
DEMO_MODE=false
