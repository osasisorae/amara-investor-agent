# ============================================
# Amara Investor Agent - Environment Variables
# Qwen Cloud Hackathon - Track 4: Autopilot Agent
# ============================================

# --- Qwen Cloud API (Agent Reasoning) ---
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE_URL=https://your-workspace.maas.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# --- Database (Turso - Persistent Memory & Audit Trail) ---
TURSO_DATABASE_URL=libsql://your-database.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# --- Email (Resend - Outreach & Agreement Delivery) ---
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL=amara@investfuturex.com

# --- File Storage (KYC Documents) ---
# Cloudflare R2 (required for KYC document storage):
R2_ACCOUNT_ID=your_r2_account_id_here
R2_ACCESS_KEY_ID=your_r2_access_key_here
R2_SECRET_ACCESS_KEY=your_r2_secret_key_here
R2_BUCKET_NAME=amara-kyc
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# --- Authentication & Security ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_secure_password_here
ADMIN_JWT_SECRET=your_admin_jwt_secret_here
INVESTOR_JWT_SECRET=your_investor_jwt_secret_here # Optional dedicated secret for investor session cookies; falls back to ADMIN_JWT_SECRET if omitted

# --- OTP Service (for Agreement Signing) ---
OTP_PROVIDER=resend
OTP_EXPIRES_IN_MINUTES=15

# --- Grey Finance (FX Rate Quotes for Payment UI) ---
GREY_API_KEY=your_grey_api_key_here # Required by lib/grey/rates.ts for exchange-rate lookups

# --- Payment Details (Grey Finance / Manual Wire) ---
FUTUREX_ACCOUNT_NAME=FutureX Nexus Development Limited
FUTUREX_NGN_BANK_NAME=Zenith Bank
FUTUREX_NGN_ACCOUNT_NUMBER=
FUTUREX_NGN_SORT_CODE=
FUTUREX_USD_BANK_NAME=Grey Finance
FUTUREX_USD_ACCOUNT_NUMBER=
FUTUREX_USD_ROUTING_NUMBER=
FUTUREX_USD_SWIFT=
FUTUREX_USDC_ETH_ADDRESS=
FUTUREX_USDC_SOL_ADDRESS=
FUTUREX_USDC_BNB_ADDRESS=
FUTUREX_USDT_BNB_ADDRESS=
FUTUREX_USDT_TRX_ADDRESS=

# --- App Configuration ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000 # Primary public app URL used across chat links, redirects, and email fallbacks

# --- Feature Flags ---
DEMO_MODE=false
